# Site Configuration
NEXT_PUBLIC_SITE_URL=https://balagpetclinic.com

# Backend API base URL including version prefix (must match `API_PREFIX` on the API, default `/api/v1`).
# Local development (copy to `.env.local`):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=https://api.balagpetclinic.com

# Ecommerce: use live catalog API when set to "false" (requires API at build time for static shop pages). Default is mock data.
# NEXT_PUBLIC_USE_MOCK_ECOMMERCE=false

# Analytics
NEXT_PUBLIC_GA_ID=

# Google Search Console (HTML tag verification value from GSC)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Server-only variables (do not prefix with NEXT_PUBLIC_)
# DATABASE_URL=
# API_SECRET_KEY=
